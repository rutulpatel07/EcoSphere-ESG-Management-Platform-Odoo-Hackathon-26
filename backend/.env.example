# Copy this file to backend/.env and fill in real values.
# backend/.env is git-ignored (it holds secrets); this template is safe to commit.

# ---- Database ----
POSTGRES_USER=ecosphere
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ecosphere_db
DATABASE_URL=postgresql+psycopg2://ecosphere:change-me@localhost:5432/ecosphere_db

# ---- Auth ----
# Generate a strong random secret, e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`.
# There is NO default — the app refuses to start without this set.
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---- App ----
ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:5173

# Feature toggles (evidence_required / auto_award_badges / auto_emission_calc /
# notifications_enabled) now live in the `settings` table (row id=1) and are
# editable via PATCH /api/settings — they are no longer environment variables.
